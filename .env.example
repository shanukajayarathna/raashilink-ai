# =============================================================
#  RaashiLink.ai — Environment Variables Template
#  Copy this file to .env (backend) and .env.local (frontend)
#  and fill in the values before running the project.
# =============================================================

# ─── Server ───────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# ─── Database ─────────────────────────────────────────────────
# Option A – MongoDB Atlas (recommended for sharing)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/raashilink?retryWrites=true&w=majority
# Option B – Local MongoDB
# MONGODB_URI=mongodb://127.0.0.1:27017/raashilink

# ─── Auth ─────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_string

# ─── Google OAuth ─────────────────────────────────────────────
# Create at https://console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# ─── AI Provider ──────────────────────────────────────────────
# Set AI_PROVIDER to: gemini | openai | groq
AI_PROVIDER=gemini

GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash

OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4

GROQ_API_KEY=your_groq_api_key
# Set this to an available Groq model from your Groq console (models change over time).
GROQ_MODEL=

# ─── Python Engine ────────────────────────────────────────────
# Path to your Python executable (must have server/python/requirements.txt installed)
PYTHON_BIN=python

# ─── Redis Cache (optional) ───────────────────────────────────
# Set REDIS_ENABLED=false to skip Redis entirely (app works without it)
REDIS_ENABLED=false
REDIS_URL=redis://127.0.0.1:6379

# ─── Vendor Document Storage ──────────────────────────────────
# local = store in server/uploads/ (default, no config needed)
# s3    = store in AWS S3 (fill in AWS vars below)
VENDOR_DOCUMENT_STORAGE=local

# AWS S3 (only needed if VENDOR_DOCUMENT_STORAGE=s3)
AWS_S3_BUCKET=your_bucket_name
AWS_REGION=eu-west-2
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_S3_PUBLIC_BASE_URL=https://your_bucket_name.s3.eu-west-2.amazonaws.com

# ─── Frontend Vite vars ───────────────────────────────────────
VITE_API_URL=http://localhost:5000
REACT_APP_API_URL=http://localhost:5000
REACT_APP_ENV=development

# ─── Firebase Phone OTP (optional – uses emulator by default) ─
FIREBASE_PROJECT_ID=demo-raashilink
FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
VITE_FIREBASE_PROJECT_ID=demo-raashilink
VITE_FIREBASE_AUTH_EMULATOR_URL=http://127.0.0.1:9099
VITE_FIREBASE_API_KEY=demo-api-key
VITE_FIREBASE_AUTH_DOMAIN=demo-raashilink.firebaseapp.com
VITE_FIREBASE_APP_ID=1:000000000000:web:demo
