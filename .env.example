REACT_APP_API_URL=http://localhost:5000
VITE_API_URL=http://localhost:5000
REACT_APP_GOOGLE_MAPS_KEY=your_key
REACT_APP_ENV=development
PORT=5000
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/raashilink?retryWrites=true&w=majority&appName=your-cluster
REDIS_ENABLED=false
REDIS_URL=redis://127.0.0.1:6379
JWT_SECRET=change_me
AI_PROVIDER=gemini
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4
GROQ_API_KEY=your_groq_api_key
# Set this to an available Groq model from your Groq console (models change over time).
GROQ_MODEL=
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash
PYTHON_BIN=python
